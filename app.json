{
  "expo": {
    "name": "Mizan",
    "slug": "mizan-legal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F5132"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.mizan.legal",
      "infoPlist": {
        "NSFaceIDUsageDescription": "يستخدم ميزان بصمة الوجه لتأمين دخولك إلى التطبيق."
      }
    },
    "android": {
      "package": "sa.mizan.legal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F5132"
      },
      "permissions": [
        "INTERNET",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      "expo-iap",
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "14780c21-5e21-40c6-984d-f826d460eb1f"
      }
    },
    "runtimeVersion": "1.0.0"
  }
}