{
  "expo": {
    "name": "Mizan",
    "slug": "mizan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mizan",
    "platforms": [
      "android",
      "ios"
    ],
    "android": {
      "package": "sa.mizan.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F5132"
      }
    },
    "ios": {
      "bundleIdentifier": "sa.mizan.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "يستخدم ميزان الميكروفون لتحويل صوتك إلى نصّ عند إدخال سؤالك صوتيّاً."
      }
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-localization",
      "expo-font",
      "expo-splash-screen",
      "./app-plugin-apkname.js",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "يستخدم ميزان الميكروفون لتحويل صوتك إلى نصّ عند إدخال سؤالك صوتيّاً.",
          "speechRecognitionPermission": "يستخدم ميزان التعرّف على الكلام لتحويل صوتك إلى نصّ داخل المحادثة.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64d231cd-9597-48ac-bdba-b2d7c60466e5"
      },
      "supportsRTL": true,
      "forcesRTL": true
    },
    "icon": "./assets/icon.png",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/64d231cd-9597-48ac-bdba-b2d7c60466e5"
    }
  }
}