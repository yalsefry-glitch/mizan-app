{
  "expo": {
    "name": "ميزان",
    "slug": "mizan-legal",
    "version": "1.7.0",
    "orientation": "portrait",
    "icon": "./assets/icon-512.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "sa.mizan.legal",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "يستخدم ميزان الكاميرا لتصوير المستندات القانونية وتحليلها استرشادياً. لا تُحفظ الصور على أي خادم.",
        "NSPhotoLibraryUsageDescription": "يتيح ميزان اختيار صورة مستند من معرضك لتحليلها استرشادياً. لا تُحفظ الصور على أي خادم.",
        "NSMicrophoneUsageDescription": "يستخدم ميزان الميكروفون للإدخال الصوتي لأسئلتك القانونية على جهازك.",
        "NSFaceIDUsageDescription": "يستخدم ميزان معرّف الوجه أو البصمة لقفل التطبيق وحماية خصوصيتك."
      }
    },
    "android": {
      "package": "sa.mizan.legal",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-512.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "يتيح ميزان اختيار صورة مستند من معرضك لتحليلها استرشادياً.",
          "cameraPermission": "يستخدم ميزان الكاميرا لتصوير المستندات القانونية وتحليلها استرشادياً."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-512.png",
          "color": "#0F172A"
        }
      ],
      "expo-secure-store",
      "expo-local-authentication",
      "./plugins/withIapStore"
    ],
    "extra": {
      "eas": {
        "projectId": "14780c21-5e21-40c6-984d-f826d460eb1f"
      }
    }
  }
}
